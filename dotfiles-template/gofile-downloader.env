# Speicherort für Downloads (Pfad muss bereits existieren)
GF_DOWNLOAD_DIR="/media/SG2TB/M/DL/"

# Manuelle Dateiauswahl (1 = aktiviert)
# GF_INTERACTIVE="1"

# Optionaler Account-Token
# GF_TOKEN="your_account_token_here"

# Maximale parallele Downloads
# GF_MAX_CONCURRENT_DOWNLOADS="5"

# Wiederholungsversuche bei Timeout
# GF_MAX_RETRIES="5"

# Verbindungs-Timeout in Sekunden
# GF_TIMEOUT="15.0"

# Bytes pro Chunk (Standard: 2 MB)
# GF_CHUNK_SIZE="2097152"

# Browser User-Agent
# GF_USERAGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64)..."
